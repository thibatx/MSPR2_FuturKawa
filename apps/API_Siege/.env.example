DATABASE_URL="postgresql://postgres:postgres@localhost:5432/appdb?schema=public"
JWT_SECRET="dev-secret-change-me"
JWT_EXPIRES_IN="7d"
PORT=3000

# API des pays (communication sécurisée par clé partagée x-api-key)
# Les clés doivent correspondre à API_KEY dans apps/API_Colombia/.env et apps/API_Brazil/.env
COLOMBIA_API_URL="http://localhost:3002/api"
COLOMBIA_API_KEY="change-me-colombia-key"
BRAZIL_API_URL="http://localhost:3003/api"
BRAZIL_API_KEY="change-me-brazil-key"
